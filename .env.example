# ── Discord Bot ──────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token

# ── Permission roles ────────────────────────────────────
# Comma-separated Discord role IDs, leave empty if not needed
# Guild owner is always Admin regardless of these settings
# How to get role ID: Discord Settings → Advanced → Developer Mode → right-click role → Copy Role ID
DISCORD_ADMIN_ROLE_IDS=
DISCORD_TRUSTED_ROLE_IDS=

# ── Anthropic ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_api_key
# Available models: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001
MODEL=claude-sonnet-4-6

# ── GitHub (memory repo) ────────────────────────────────
GITHUB_TOKEN=ghp_your_personal_access_token
MEMORY_REPO_OWNER=your_github_username
# Will be auto-created as a private repo if it doesn't exist
MEMORY_REPO_NAME=claude-agent-memory

# ── Session ─────────────────────────────────────────────
# How long (minutes) a conversation session stays alive before expiring
SESSION_TTL_MINUTES=60

# ── Rate limiting ───────────────────────────────────────
# Max requests per hour per user, by permission tier
# Everyone: users without any special role
# Trusted: users with a trusted role
# Admin: unlimited (no rate limit)
RATE_LIMIT_EVERYONE=20
RATE_LIMIT_TRUSTED=100

# ── Agent settings ──────────────────────────────────────
# Max conversation turns per agent query
MAX_TURNS=20
# Timeout in seconds for each agent query
AGENT_QUERY_TIMEOUT=120
# Health check HTTP port (for Docker / orchestrator liveness probes)
HEALTH_CHECK_PORT=8080
# Python logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
